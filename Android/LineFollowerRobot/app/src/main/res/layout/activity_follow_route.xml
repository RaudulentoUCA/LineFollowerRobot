<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_jungle"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitleFollow"
            android:text="Modo Seguir Ruta"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerRoutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:spinnerMode="dropdown"
            android:background="@drawable/card_jungle"/>

        <Button
            android:id="@+id/btnPowerFollow"
            android:text="Encender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvRunStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado: listo"
            android:textSize="14sp"
            android:background="@drawable/card_jungle"
            android:textColor="@color/text_secondary"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnDeleteSelected"
            android:text="Borrar ruta seleccionada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnDeleteAll"
            android:text="Borrar TODAS las rutas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvPreviewTitle"
            android:text="Vista previa (aprox.)"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvPreviewStats"
            android:text="Ticks: - | Distancia inicio → fin: -"
            android:textColor="@color/text_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"/>

        <com.example.LineFollowerRobot.RoutePreviewView
            android:id="@+id/routePreview"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/card_jungle" />

        <Button
            android:id="@+id/btnBackFollow"
            android:text="Volver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>